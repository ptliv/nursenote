# Supabase (필수)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (필수: AI 초안 생성 기능)
OPENAI_API_KEY=sk-...

# OpenAI 선택 옵션
# OPENAI_MODEL=gpt-4o-mini              # SOAP·실습일지 모델 (기본: gpt-4o-mini)
# OPENAI_CASE_STUDY_MODEL=gpt-4o-mini  # 케이스스터디 전용 모델 (기본: OPENAI_MODEL)
# OPENAI_TIMEOUT_MS=20000              # AI 응답 타임아웃 ms (기본: 20000)

# 기능 정책 선택 옵션 (미설정 시 기본값 사용)
# CASE_STUDY_PRO_ONLY=false            # true면 free 사용자 케이스스터디 차단
# CASE_STUDY_FREE_MONTHLY_LIMIT=5      # 0이면 월 제한 없음
# PRACTICE_LOG_PRO_ONLY=false          # true면 free 사용자 실습일지 차단
