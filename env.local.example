# Supabase (필수)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (필수: AI 초안 생성 기능)
OPENAI_API_KEY=sk-...

# OpenAI 선택 옵션
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_CASE_STUDY_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_MS=20000

# 기능 정책 선택 옵션
# CASE_STUDY_PRO_ONLY=false
# CASE_STUDY_FREE_MONTHLY_LIMIT=5
# PRACTICE_LOG_PRO_ONLY=false
