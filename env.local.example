# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 서버 전용 (클라이언트 노출 금지)

# OpenAI
OPENAI_API_KEY=sk-...                              # 필수: AI SOAP 기능
OPENAI_MODEL=gpt-4o-mini                           # 선택: 기본값 gpt-4o-mini
OPENAI_CASE_STUDY_MODEL=gpt-4o-mini                # 선택: 케이스스터디 전용 모델

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Case Study Policy
CASE_STUDY_PRO_ONLY=false                          # true면 free 사용자 차단
CASE_STUDY_FREE_MONTHLY_LIMIT=5                    # 0이면 월 제한 없음
